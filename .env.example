# Database (Postgres + PostGIS)
# Local: docker compose up postgres
DATABASE_URL=postgresql://padel:padel@localhost:5433/padel_tours

# Adapters: set to "mock" to use mock data, "live" to hit real providers
# Phase 0/1 dev: use "mock". Once you have real provider IDs, switch to "live".
ADAPTERS_MODE=mock

# Cache TTL in seconds (default: 180 = 3 min)
CACHE_TTL_SECONDS=180

# Optional: Mapbox token for address geocoding (50k req/mois gratuit)
# https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=

# Optional: Sentry DSN for adapter error monitoring
SENTRY_DSN=

# Default search center (Tours, place Anatole-France) used as fallback if geoloc denied
DEFAULT_LAT=47.39414
DEFAULT_LNG=0.68484
